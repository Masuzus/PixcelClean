{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pixel Clean",
  "version": "2.0.0-alpha.1",
  "identifier": "com.pixelclean.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pixel Clean 2.0 Alpha",
        "width": 1280,
        "height": 800,
        "minWidth": 980,
        "minHeight": 650
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
